# ─────────────────────────────────────────────
# Nifty-100 Analytics Project — Environment Config
# Copy to .env and fill in values; never commit .env
# ─────────────────────────────────────────────

# Project root (set automatically by Makefile; override if needed)
PROJECT_ROOT=.

# Database
DB_PATH=nifty100.db

# Raw data directory (place source Excel files here)
RAW_DATA_DIR=data/raw

# Output directory for CSVs, audit logs, etc.
OUTPUT_DIR=output

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/pipeline.log

# SQLite PRAGMA settings
SQLITE_FOREIGN_KEYS=ON
SQLITE_JOURNAL_MODE=WAL
